# Copy to .env and fill in values
API_AUTH_ENABLED=false
BOARD_API_KEY=change-me
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# --- LLM (commentary + takeaways) — pick one provider ---
# anthropic | openai | openrouter | gemini | ollama
LLM_PROVIDER=anthropic
# Optional override for any provider (otherwise use provider-specific keys below)
# LLM_API_KEY=
# Optional: model id (defaults per provider if unset)
# LLM_MODEL=
# LLM_HTTP_TIMEOUT_SEC=90
# For OpenAI-compatible proxies (OpenAI + OpenRouter + Ollama). Examples:
#   OpenRouter: https://openrouter.ai/api/v1
#   Ollama (Docker→host): http://host.docker.internal:11434/v1
# LLM_BASE_URL=

# Ollama (local): OpenAI-compatible http://host:11434/v1 — no key required by default
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_API_KEY=          # optional; if Ollama is configured with auth

# Provider-specific keys (used when LLM_API_KEY is empty)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
GEMINI_API_KEY=

# OpenRouter optional attribution headers (https://openrouter.ai/docs)
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_X_TITLE=BoardSight

STOCKFISH_PATH=/usr/games/stockfish   # or /opt/homebrew/bin/stockfish on Mac
STOCKFISH_UCI_TIMEOUT_SEC=120          # per-position UCI wait; raise on slow home VPS
DATABASE_URL=postgresql://boardsight:boardsight@localhost:5432/boardsight
REDIS_URL=redis://localhost:6379/0
